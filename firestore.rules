rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: saves
    // Document ID: {userId}
    // Fields:
    //   - gameState: string (required) - JSON stringified game state
    //   - updatedAt: timestamp (required) - Timestamp of the last save
    //   - stage: number (required) - The highest stage reached by the user
    //   - displayName: string (required) - The user's display name
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    // Check if the user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Check if user owns the resource (for user-owned documents)
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    // Validate required fields exist
    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }
    
    // Validate that the document contains only the allowed fields
    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // Domain Validators
    function isValidSaveData(data) {
      return hasOnlyAllowedFields(['gameState', 'updatedAt', 'stage', 'displayName']) &&
             data.gameState is string && data.gameState.size() > 0 && data.gameState.size() < 1000000 && // limit to 1MB
             data.updatedAt is timestamp &&
             data.stage is number && data.stage >= 1 &&
             data.displayName is string && data.displayName.size() > 0 && data.displayName.size() < 100;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /saves/{userId} {
      // Anyone can read saves for the leaderboard
      allow read: if true;
      
      // Only the owner can create or update their save data
      allow create: if isOwner(userId) && isValidSaveData(request.resource.data);
      allow update: if isOwner(userId) && isValidSaveData(request.resource.data);
      allow delete: if false; // Do not allow deletion for now
    }
  }
}
